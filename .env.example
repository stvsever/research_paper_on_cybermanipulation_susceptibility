# Required
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Recommended runtime choice for the pilot pipeline
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Optional metadata headers if you later choose to wire them through environment variables
OPENROUTER_HTTP_REFERER=https://ghent-research.local
OPENROUTER_APP_TITLE=GhentUniversity_AttackOpinionSimulation

# Optional Postgres projection for canonical pipeline artifacts.
# Used by: python -m src.backend.persistence.ingest_pipeline_run --run-id run_12
# Example local value for docker/docker-compose.postgres.yml
DATABASE_URL=postgresql://csw:csw_localdev@127.0.0.1:5432/cognitive_sovereignty
