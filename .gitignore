# Production run 1 (full 10,000-scenario individual-layer run): the per-row and
# per-scenario tables exceed GitHub's 100 MB limit and are regenerable. The essential
# per-(scenario, leaf) deltas (baseline B, post-attack P, delta, adversarial
# effectivity) are committed compressed as sem_long_raw.csv.gz, and the full source
# content of any scenario is recoverable by joining the integrated set on scenario_id.
evaluation/production/run_1/stage_outputs/01_create_scenarios/scenarios.json
evaluation/production/run_1/stage_outputs/01_create_scenarios/scenarios.jsonl
evaluation/production/run_1/stage_outputs/**/scenarios_with_*.jsonl
evaluation/production/run_1/stage_outputs/02_assess_baseline_opinions/baseline_assessments.jsonl
evaluation/production/run_1/stage_outputs/04_assess_post_attack_opinions/post_attack_assessments.jsonl
evaluation/production/run_1/stage_outputs/05_compute_effectivity_deltas/sem_long_raw.csv
evaluation/production/run_1/stage_outputs/05_compute_effectivity_deltas/sem_long_encoded.csv
evaluation/production/run_1/stage_outputs/05_compute_effectivity_deltas/profile_sem_wide.csv

