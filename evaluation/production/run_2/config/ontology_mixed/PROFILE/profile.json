{
  "_metadata": {
    "taxonomy_description": "Hierarchical taxonomy of inter-individual differences with documented relevance to susceptibility to cyber-manipulation of political opinion. Variables are selected for direct mappability to standard social-science survey instruments (ESS, Eurobarometer, ANES, GSS, British Social Attitudes). The tree mixes (a) continuous trait inventories with facet substructure and (b) categorical single-select dimensions. Structure is discovered generically by the pipeline: no inventory names are hardcoded.",
    "inventory_rationales": {
      "Big_Five": "Canonical personality structure (NEO-PI-R facet resolution). Repeatedly implicated as a moderator of persuasibility and misinformation endorsement. Conscientiousness negatively predicts susceptibility; Neuroticism positively predicts reactivity to fear-based appeals; Openness predicts receptivity to novel framings.",
      "Age": "Chronological age is a robust demographic moderator of digital-media literacy and susceptibility to online manipulation; directly mappable to ESS/ANES/GSS age items.",
      "Sex": "Biological sex is a standard covariate in persuasion research; mappable to binary-plus-other demographic measures in ESS/Eurobarometer."
    },
    "schema_version": "v4-test-run-1-production",
    "ontology_role": "deployment",
    "title": "Person / Profile Ontology — Deployment State Space",
    "per_leaf_metadata_schema": {
      "schema_version": "v4-test-run-1-baked",
      "documentation": "Every PROFILE leaf carries STRUCTURAL combinatorial sampling metadata (modality_type, value_format, sampling_role, exclusivity_group, prevalence_weight, is_unknown_marker, construct_type, description). The ontology does NOT encode psychological-amplification hypotheses. Subtree-wide rules live in `_sampling_rules`; per-leaf inline metadata wins.",
      "fields": [
        "modality_type",
        "value_format",
        "sampling_role",
        "exclusivity_group",
        "prevalence_weight",
        "is_unknown_marker",
        "construct_type",
        "description"
      ]
    },
