    "drop_direction_neutral_opinions": true
  },
  "attack_sampling": {
    "ontology_axis": "ATTACK",
    "panel_file": "evaluation/production/run_2/config/attack_panel.json",
    "selection_mode": "explicit_leaves",
    "attack_ratio": 1.0
  },
  "pipeline": {
    "entrypoint": "src/backend/pipeline/full/run_full_pipeline.py",
    "resume_from_stage": "01",
    "stop_after_stage": "08b",
    "analyze_network_exposure_run": true,
    "use_test_ontology": false,
    "enforce_compatibility_rules": true,
    "realism_weight_temperature": 1.5,
    "generate_visuals": true,
    "export_static_figures": true,
    "build_report": false,
    "ingest_to_db": false
  },
  "network_layer": {
    "assess_network_exposure": true,
    "network_exposure_top_k": 8,
    "assess_post_attack_network_exposure": true,
    "post_attack_network_exposure_top_k": 8,
    "post_attack_network_min_peers": 1,
    "exposure_graph_id": "politisky24_bluesky_v1",
    "exposure_assignment_mode": "ranked_seeded_profiles"
  },
  "model_settings": {
    "openrouter_model": "deepseek/deepseek-v4-flash",
    "temperature": 0.15,
    "max_repair_iter": 2,
    "self_supervise_attack_realism": true,
    "realism_threshold": 0.72,
    "self_supervise_opinion_coherence": true,
    "coherence_threshold": 0.74,
    "save_raw_llm": true,
    "timeout_sec": 90,
    "max_concurrency": 12
  },
  "preflight_modes": {
    "structural": {
      "output_root": "evaluation/production/run_2/preflight/structural_full_factorial",
      "n_profiles": 100,
